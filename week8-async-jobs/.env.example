# MongoDB (Local)
MONGO_URI=mongodb://localhost:27017/week8_async_jobs
# OR MongoDB Atlas (replace <username> and <password> with your credentials)
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/week8_async_jobs?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# Redis (matches docker-compose service)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Node environment
NODE_ENV=development

# Port
PORT=3000
